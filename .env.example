# AI/ML API (OpenAI-compatible) — required for agent calls
AIML_API_KEY=your-aiml-api-key-here
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o-mini

# Shared workflow state (required on Railway multi-service deploy)
# Option A (recommended): PostgreSQL — set on web + all 4 agent services
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# Option B: Railway volume mounted at /data on web + all 4 agent services
# MEDBAND_DATA_DIR=/data

# Active healthcare sector (pharmacy, hospital_triage, lab, mental_health, hmo_claims, emergency)
ACTIVE_SECTOR=pharmacy

# Phase 2 Band credentials (add on June 12 - do not use in Phase 1)
# COORDINATOR_AGENT_ID=
# COORDINATOR_API_KEY=
# INTAKE_AGENT_ID=
# INTAKE_API_KEY=
# VERIFICATION_AGENT_ID=
# VERIFICATION_API_KEY=
# RESOURCE_AGENT_ID=
# RESOURCE_API_KEY=
